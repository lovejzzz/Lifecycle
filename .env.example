# Lifecycle Agent — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# At least one provider key is required.

# Primary AI provider (DeepSeek — OpenAI-compatible, fast & capable)
DEEPSEEK_API_KEY=

# Anthropic AI provider (Claude models — selected via model picker)
ANTHROPIC_API_KEY=

# Fallback AI provider (OpenRouter — multiple models)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
